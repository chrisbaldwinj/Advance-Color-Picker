<UserControl
    x:Class="YourSolution.Controls.AdvancedColorPickerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:YourSolution.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="root"
    d:DesignHeight="40"
    d:DesignWidth="80"
    Loaded="Root_Loaded"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  Converters  -->
        <local:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <local:CenteredOffsetConverter x:Key="CenteredOffsetConverter" />
        <local:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <local:OpaqueColorConverter x:Key="OpaqueColorConverter" />

        <!--  Style for the color swatch buttons  -->
        <Style x:Key="ColorButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="buttonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="4"
                                    Opacity="0.2"
                                    ShadowDepth="1"
                                    Color="Black" />
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="buttonBorder" Property="BorderBrush" Value="DodgerBlue" />
                                <Setter TargetName="buttonBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Custom Slider Thumb Style  -->
        <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Grid>
                            <Ellipse
                                x:Name="grip"
                                Width="18"
                                Height="18"
                                Fill="White"
                                Stroke="LightGray"
                                StrokeThickness="1">
                                <Ellipse.Effect>
                                    <DropShadowEffect
                                        BlurRadius="2"
                                        Direction="270"
                                        Opacity="0.3"
                                        ShadowDepth="1" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="grip" Property="Fill" Value="#FFF0F0F0" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="grip" Property="Fill" Value="#FFE8E8E8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Custom Slider Track Style  -->
        <Style x:Key="SliderTrackStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Rectangle Height="10" Fill="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Main Slider Style  -->
        <Style x:Key="CustomSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid VerticalAlignment="Center">
                            <Border
                                x:Name="TrackBackground"
                                Height="10"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5" />
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{StaticResource SliderTrackStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{StaticResource SliderTrackStyle}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  A dedicated style for the Alpha Slider to create a layered, bindable background  -->
        <Style x:Key="AlphaSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid VerticalAlignment="Center">
                            <!--  This Grid creates the layered background  -->
                            <Grid x:Name="TrackBackgroundGrid" Height="10">
                                <!--  Layer 1: Checkerboard background  -->
                                <Rectangle RadiusX="5" RadiusY="5" />
                                <!--  Layer 2: Gradient from transparent to the opaque version of the active color  -->
                                <Rectangle RadiusX="5" RadiusY="5">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Offset="0.0" Color="Transparent" />
                                            <!--  This binding will now update correctly because it's not inside a VisualBrush  -->
                                            <GradientStop Offset="1.0" Color="{Binding ActiveColor, ElementName=root, Converter={StaticResource OpaqueColorConverter}}" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{StaticResource SliderTrackStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{StaticResource SliderTrackStyle}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!--  This is the main button area to open the picker  -->
        <StackPanel
            x:Name="ButtonPanel"
            Orientation="Horizontal"
            Visibility="{Binding HideButton, ElementName=root, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}">
            <Button
                x:Name="PrimaryButton"
                Background="{Binding SelectedColor, ElementName=root, Converter={StaticResource ColorToBrushConverter}}"
                Click="PrimaryButton_Click"
                Style="{StaticResource ColorButtonStyle}" />

            <Button
                x:Name="SecondaryButton"
                Margin="8,0,0,0"
                Background="{Binding SecondaryColor, ElementName=root, Converter={StaticResource ColorToBrushConverter}}"
                Click="SecondaryButton_Click"
                Style="{StaticResource ColorButtonStyle}"
                Visibility="{Binding EnableSecondary, ElementName=root, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <!--  The Picker Popup  -->
        <Popup
            x:Name="ColorPickerPopup"
            AllowsTransparency="True"
            Closed="ColorPickerPopup_Closed"
            CustomPopupPlacementCallback="CustomPopupPlacementCallback"
            Opened="ColorPickerPopup_Opened"
            Placement="Custom"
            PlacementTarget="{Binding ElementName=ButtonPanel}"
            PopupAnimation="Fade"
            StaysOpen="False">

            <Border
                x:Name="PickerBorder"
                Width="260"
                Padding="15"
                CornerRadius="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#FFFFFFFF" />
                        <Setter Property="BorderBrush" Value="#FFD0D0D0" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Opacity="0.15"
                                    ShadowDepth="2"
                                    Color="Black" />
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDarkMode, ElementName=root}" Value="True">
                                <Setter Property="Background" Value="#FF3C3C3C" />
                                <Setter Property="BorderBrush" Value="#FF505050" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!--  Saturation/Value Canvas  -->
                    <Grid
                        x:Name="SVCanvas"
                        Height="150"
                        MouseDown="SVCanvas_MouseDown"
                        MouseMove="SVCanvas_MouseMove">
                        <Rectangle RadiusX="4" RadiusY="4">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="White" />
                                    <GradientStop x:Name="HueGradientStop" Offset="1" Color="Red" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle RadiusX="4" RadiusY="4">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="#00FFFFFF" />
                                    <GradientStop Offset="1" Color="#FF000000" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Ellipse
                            x:Name="SVSelector"
                            Width="14"
                            Height="14"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            IsHitTestVisible="False"
                            Stroke="White"
                            StrokeThickness="2">
                            <Ellipse.RenderTransform>
                                <TranslateTransform x:Name="SVSelectorPosition" />
                            </Ellipse.RenderTransform>
                            <Ellipse.Effect>
                                <DropShadowEffect
                                    BlurRadius="3"
                                    Opacity="0.5"
                                    ShadowDepth="0"
                                    Color="Black" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>

                    <!--  Sliders StackPanel  -->
                    <StackPanel Margin="0,15,0,0">
                        <!--  Hue Slider  -->
                        <Slider
                            Maximum="359.9"
                            Minimum="0"
                            PreviewMouseDown="Slider_PreviewMouseDown"
                            Style="{StaticResource CustomSliderStyle}"
                            Value="{Binding Hue, ElementName=root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <Slider.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Offset="0.0" Color="Red" />
                                    <GradientStop Offset="0.166" Color="Yellow" />
                                    <GradientStop Offset="0.333" Color="Lime" />
                                    <GradientStop Offset="0.5" Color="Cyan" />
                                    <GradientStop Offset="0.666" Color="Blue" />
                                    <GradientStop Offset="0.833" Color="Magenta" />
                                    <GradientStop Offset="1.0" Color="Red" />
                                </LinearGradientBrush>
                            </Slider.Background>
                        </Slider>

                        <!--  Alpha Slider  -->
                        <Slider
                            x:Name="AlphaSlider"
                            Margin="0,10,0,0"
                            Maximum="1"
                            Minimum="0"
                            Style="{StaticResource AlphaSliderStyle}"
                            Value="{Binding Alpha, ElementName=root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!--  Hex Input & Color Preview  -->
                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="34"
                            Height="34"
                            BorderThickness="1"
                            CornerRadius="17">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFD0D0D0" />
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="{Binding SelectedColor, ElementName=root}" />
                            </Border.Background>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFF5F5F5" />
                                    <Setter Property="BorderBrush" Value="#FFE0E0E0" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkMode, ElementName=root}" Value="True">
                                            <Setter Property="Background" Value="#FF4A4A4A" />
                                            <Setter Property="BorderBrush" Value="#FF5A5A5A" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBox
                                x:Name="HexTextBox"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Consolas"
                                FontSize="14"
                                FontWeight="Medium"
                                GotFocus="HexTextBox_GotFocus"
                                Text="{Binding HexValue, ElementName=root, Mode=TwoWay, UpdateSourceTrigger=LostFocus}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Foreground" Value="#FF333333" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkMode, ElementName=root}" Value="True">
                                                <Setter Property="Foreground" Value="#FFDDDDDD" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Border>
                    </Grid>

                    <!--  Swatches  -->
                    <WrapPanel
                        x:Name="SwatchPanel"
                        Margin="0,15,0,0"
                        HorizontalAlignment="Center" />

                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>

